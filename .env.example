# ── App ───────────────────────────────────────────────────────────────────────
# Comma-separated Gemini API keys (free first, paid last). Auto-fallback on quota exhaustion.
GEMINI_API_KEYS=""
# Legacy single-key fallback (used if GEMINI_API_KEYS is not set)
GEMINI_API_KEY=""
APP_URL="http://localhost:3000"

# ── Supabase (frontend — VITE_ prefix required) ───────────────────────────────
# Dashboard → Project Settings → API
VITE_SUPABASE_URL=""        # https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=""   # public anon key (safe to expose in browser)

# ── Supabase (backend/server — NO VITE_ prefix, never sent to browser) ────────
SUPABASE_URL=""             # same URL as above
SUPABASE_SERVICE_ROLE_KEY="" # secret service role key — grants full DB access, keep private

# ── Admin Auth ────────────────────────────────────────────────────────────────
# Run GET /admin/setup?password=yourpassword once (while ADMIN_PASSWORD is unset)
# to generate the bcrypt hash, then paste it here and restart.
ADMIN_PASSWORD=""
# Any random 32+ character string — used to sign session cookies.
SESSION_SECRET=""

# ── Instamojo (payments) ──────────────────────────────────────────────────────
# Dashboard → API → Credentials
# Test: https://test.instamojo.com  |  Live: https://api.instamojo.com
INSTAMOJO_API_KEY=""       # starts with "test_" for sandbox, live key for production
INSTAMOJO_AUTH_TOKEN=""    # auth token — server-side only, never expose to browser
INSTAMOJO_SALT=""          # webhook MAC secret — used to verify Instamojo callbacks

# ── Firebase (PWA push notifications) ────────────────────────────────────────
# Frontend config — all VITE_ prefixed (safe to ship to browser)
# Firebase Console → Project Settings → General → Your apps → Web app
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""     # xxxxxxxxxxxx.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""  # xxxxxxxxxxxx.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
# Firebase Console → Project Settings → Cloud Messaging → Web configuration → Key pair
VITE_FIREBASE_VAPID_KEY=""       # Web Push certificate public key (VAPID)

# Backend — Firebase Admin SDK service account (server only, never expose to browser)
# Firebase Console → Project Settings → Service accounts → Generate new private key
# Paste the entire JSON on ONE line (escape any internal quotes)
FIREBASE_SERVICE_ACCOUNT_JSON=''

# ── Optional news APIs ────────────────────────────────────────────────────────
# These supplement the RSS feeds. Leave blank to use RSS-only mode.
FINNHUB_API_KEY=""
MARKETAUX_API_KEY=""
NEWSAPI_API_KEY=""
